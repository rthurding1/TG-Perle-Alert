# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (send /start to @userinfobot to get it)
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ALLOWED_USER_IDS=8626366848

# DexScreener pair address for $PRL (find at dexscreener.com)
# Default uses search — set a specific pair address for reliability
PRL_PAIR_ADDRESS=

# Polling interval in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# Cooldown before re-alerting same threshold in hours (default: 4)
COOLDOWN_HOURS=4

# FDV threshold step size in millions (default: 25)
THRESHOLD_STEP_M=25
